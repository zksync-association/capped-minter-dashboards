# Get a free project ID at https://cloud.walletconnect.com/
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_project_id_here

# Supported Chains (324 = zkSync Era mainnet, 300 = zkSync Sepolia).
# App is single-chain; no in-app network switching.
NEXT_PUBLIC_CHAIN_ID=324

# Subgraph GraphQL endpoint
NEXT_PUBLIC_SUBGRAPH_URL=your_subraph_url_here

# Optional: Governance proposal base URL used to construct links from proposalId
# Example (Tally): https://www.tally.xyz/gov/zksync/proposal/
NEXT_PUBLIC_GOVERNANCE_PROPOSAL_BASE_URL=